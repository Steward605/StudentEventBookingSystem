# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Vue / Vite build output
dist/
frontend/dist/

# Environment variables / secrets
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# Keep example env files if you create them
!.env.example
!frontend/.env.example
!backend/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Backend database files
backend/data/*.sqlite
backend/data/*.sqlite-journal
backend/data/*.sqlite-shm
backend/data/*.sqlite-wal

# SQLite database files
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# OS files
.DS_Store
Thumbs.db

# Editor / IDE files
.vscode/
.idea/

# Capacitor / Android generated files
android/.gradle/
android/local.properties
android/**/build/
android/**/.cxx/
android/.idea/
android/*.iml
android/captures/
android/.externalNativeBuild/

# Android output packages
*.apk
*.aab

# Android signing keys - never commit these
*.jks
*.keystore